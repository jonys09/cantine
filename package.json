{
  "name": "la-cantine",
  "private": true,
  "sideEffects": false,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "shopify hydrogen build",
    "build:vercel": "vite build --config vite.vercel.config.ts && vite build --config vite.vercel.config.ts --ssr",
    "build:deploy": "vite build --config vite.vercel.config.ts && vite build --config vite.vercel.config.ts --ssr && node scripts/prepare-deploy.js",
    "start": "node api/index.js",
    "dev": "shopify hydrogen dev --codegen",
    "preview": "npm run build && shopify hydrogen preview",
    "lint": "eslint --no-error-on-unmatched-pattern --ext .js,.ts,.tsx .",
    "typecheck": "tsc --noEmit",
    "codegen": "shopify hydrogen codegen",
    "shopifydev": "shopify hydrogen dev"
  },
  "dependencies": {
    "@react-router/dev": "7.12.0",
    "@react-router/express": "^7.12.0",
    "@shopify/hydrogen": "2026.1.1",
    "@types/express": "^5.0.6",
    "express": "^5.2.1",
    "graphql": "^16.9.0",
    "graphql-tag": "^2.12.6",
    "isbot": "^5.1.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "7.12.0",
    "react-router-dom": "7.12.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.3",
    "@react-router/fs-routes": "7.12.0",
    "@shopify/cli": "3.91.0",
    "@shopify/cli-hydrogen": "11.1.10",
    "@shopify/hydrogen-codegen": "^0.3.2",
    "@shopify/mini-oxygen": "4.0.1",
    "@shopify/oxygen-workers-types": "^4.1.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vite": "^6.2.1",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
