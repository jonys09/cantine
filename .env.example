# ── Required: set this yourself (any random 32+ char string) ──────────────
SESSION_SECRET=your-random-secret-here

# ── Auto-injected by `shopify hydrogen dev` after linking your store ───────
# Run: shopify hydrogen link --store your-store.myshopify.com
# Then these are populated automatically. Or fill in manually from:
# Shopify Admin → Settings → Apps & sales channels → Develop apps

PUBLIC_STOREFRONT_API_TOKEN=
PRIVATE_STOREFRONT_API_TOKEN=
PUBLIC_STORE_DOMAIN=your-store.myshopify.com
PUBLIC_STOREFRONT_ID=

# ── Customer accounts (optional — leave blank if not using) ───────────────
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=
PUBLIC_CUSTOMER_ACCOUNT_API_URL=
SHOP_ID=
